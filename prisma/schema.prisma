generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Single key-value store mirrors the Supabase app_store table.
// All values are stored as JSON strings.
model KvStore {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt

  @@map("kv_store")
}
